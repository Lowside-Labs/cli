{
  "name": "npx-proxy",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Worker — proxies Firecrawl and Anthropic API calls with rate limiting",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:secrets": "node -e \"const f=require('fs').readFileSync('.dev.vars','utf8');const o=Object.fromEntries(f.trim().split('\\n').map(l=>{const[k,...v]=l.split('=');return[k,v.join('=')]}));process.stdout.write(JSON.stringify(o))\" | wrangler secret bulk",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  }
}
